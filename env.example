# Spine environment — sourced by ~/.zshenv via install.sh
# Copy to ~/.config/spine/.env and uncomment as needed.

# --- MCP server API keys (optional — both work keyless) ---
# export EXA_API_KEY=your-key-here
# export CONTEXT7_API_KEY=your-key-here

# --- Multi-provider dispatch ---
# Default: claude,codex,cursor + opencode (when available).
# Override to use a static list. Extensible: add provider when check-<provider>.sh + invoke-<provider>.sh exist.
# export SPINE_ENVOY_PROVIDERS=claude,codex,cursor,opencode

# --- Envoy model overrides ---
# Format: model[:effort]  (effort defaults to "high" if omitted)
# Note: a base override without effort (e.g., SPINE_ENVOY_CLAUDE=opus) defaults
# effort to "high" for every tier. Set an explicit effort to match a specific tier.
# export SPINE_ENVOY_CLAUDE=opus:high
# export SPINE_ENVOY_CODEX=gpt-5.4:high
# export SPINE_ENVOY_CURSOR=composer-2.5
# export SPINE_ENVOY_OPENCODE=opencode-go/qwen3.6-plus:high

# --- Per-tier envoy overrides ---
# Format: SPINE_ENVOY_{TIER}_{PROVIDER}=model[:effort]
# Tier-specific vars take precedence over the base SPINE_ENVOY_{PROVIDER} vars above.
# export SPINE_ENVOY_FRONTIER_CLAUDE=opus:max
# export SPINE_ENVOY_FRONTIER_CODEX=gpt-5.5:xhigh
# export SPINE_ENVOY_FRONTIER_CURSOR=composer-2.5
# export SPINE_ENVOY_STANDARD_CLAUDE=sonnet:high
# export SPINE_ENVOY_STANDARD_CODEX=gpt-5.5:medium
# export SPINE_ENVOY_STANDARD_CURSOR=composer-2.5
# export SPINE_ENVOY_FAST_CLAUDE=haiku:high
# export SPINE_ENVOY_FAST_CODEX=gpt-5.4-mini:high  # ideal: gpt-5.4-nano (unavailable on current Codex subscription)
# export SPINE_ENVOY_FAST_CURSOR=composer-2.5

# --- OpenCode ---
# Single provider with automatic tier detection:
#   Go tier (subscription): detected via `opencode models opencode-go` — no config needed.
#   Free tier (Zen -free): detected via `opencode models opencode` — no config needed.
# Models are selected automatically based on available tier.
#
# Multi-model fanout (default-on, per slice 2 verifier):
#   Frontier: kimi-k2.6 + deepseek-v4-pro + glm-5.1 (3 models, parallel dispatch)
#   Standard: minimax-m2.7 + deepseek-v4-pro + qwen3.6-plus + mimo-v2.5-pro (4 models, parallel dispatch)
#   Fast: deepseek-v4-flash + qwen3.5-plus + minimax-m2.5 (3 models, parallel dispatch)
#
# Per-tier override disables fanout (single-model):
# export SPINE_ENVOY_FRONTIER_OPENCODE=opencode-go/kimi-k2.6:high
# export SPINE_ENVOY_STANDARD_OPENCODE=opencode-go/minimax-m2.7:high
# export SPINE_ENVOY_FAST_OPENCODE=opencode-go/deepseek-v4-flash:high
#
# Global override (all tiers, also disables fanout):
# export SPINE_ENVOY_OPENCODE=opencode-go/kimi-k2.6:high
#
# Fanout-only override (keep multi-model, replace fanout list):
# export SPINE_OPENCODE_FANOUT=1  # force fanout even if env override is set
# export SPINE_OPENCODE_FRONTIER_FANOUT=opencode-go/kimi-k2.6 opencode-go/deepseek-v4-pro opencode-go/glm-5.1

# --- Fallback ---
# Cursor-agent fallback is automatic — no env var overrides.
# When Claude/Codex CLI fails (rate limit, auth error), invoke scripts retry
# via cursor-agent with the same model. See docs/model-selection.md for details.
# export SPINE_ENVOY_DEBUG=1  # show fallback decision path on stderr

# --- Diagnostics ---
# Enable hook diagnostic logging (JSONL). Logs to ~/.config/spine/logs/hooks.jsonl.
# Rotate at ~500 KB; keeps last 2 rotated files. Any non-empty value enables; unset to disable (setting to 0 also enables).
# export SPINE_HOOK_LOG=1
