# Spine environment — sourced by ~/.zshenv via install.sh
# Copy to ~/.config/spine/.env and uncomment as needed.

# --- MCP server API keys (optional — both work keyless) ---
# export EXA_API_KEY=your-key-here
# export CONTEXT7_API_KEY=your-key-here

# --- Multi-provider dispatch ---
# Ordered priority list of providers to attempt. Default: all non-self.
# Extensible: add provider name when check-<provider>.sh + invoke-<provider>.sh exist.
# export SPINE_ENVOY_PROVIDERS=claude,codex,cursor,qwen,glm,minimax,deepseek

# --- Envoy model overrides ---
# Format: model[:effort]  (effort defaults to "high" if omitted)
# Note: a base override without effort (e.g., SPINE_ENVOY_CLAUDE=opus) defaults
# effort to "high", which is lower than frontier's "max". Use explicit effort to match.
# export SPINE_ENVOY_CLAUDE=opus:high
# export SPINE_ENVOY_CODEX=gpt-5.4:high
# export SPINE_ENVOY_CURSOR=composer-2
# export SPINE_ENVOY_QWEN=qwen3-coder-plus  # no effort parameter
# export SPINE_ENVOY_COPILOT=gpt-5.4:medium  # Copilot uses --effort (low/medium/high/xhigh)

# --- Per-tier envoy overrides ---
# Format: SPINE_ENVOY_{TIER}_{PROVIDER}=model[:effort]
# Tier-specific vars take precedence over the base SPINE_ENVOY_{PROVIDER} vars above.
# export SPINE_ENVOY_FRONTIER_CLAUDE=opus:max
# export SPINE_ENVOY_FRONTIER_CODEX=gpt-5.4:xhigh
# export SPINE_ENVOY_FRONTIER_CURSOR=composer-2
# export SPINE_ENVOY_STANDARD_CLAUDE=sonnet:high
# export SPINE_ENVOY_STANDARD_CODEX=gpt-5.4:medium
# export SPINE_ENVOY_STANDARD_CURSOR=composer-2
# export SPINE_ENVOY_FAST_CLAUDE=haiku:high
# export SPINE_ENVOY_FAST_CODEX=gpt-5.4-mini:high  # ideal: gpt-5.4-nano (unavailable on current Codex subscription)
# export SPINE_ENVOY_FAST_CURSOR=composer-2
# export SPINE_ENVOY_FRONTIER_QWEN=qwen3.5-plus
# export SPINE_ENVOY_STANDARD_QWEN=qwen3-coder-plus
# export SPINE_ENVOY_FAST_QWEN=coder-model  # OAuth free tier resolves all to coder-model
# export SPINE_ENVOY_FRONTIER_COPILOT=gpt-5.4:xhigh
# export SPINE_ENVOY_STANDARD_COPILOT=gpt-5.4:medium
# export SPINE_ENVOY_FAST_COPILOT=gpt-5.4-mini:high

# --- OpenCode-based providers (GLM, MiniMax, DeepSeek) ---
# All use `opencode` CLI. Model format: full prefixed ID (e.g., opencode-go/glm-5).
# Effort passed as --variant flag (high, minimal, max).
# export SPINE_ENVOY_GLM=opencode-go/glm-5:high
# export SPINE_ENVOY_MINIMAX=opencode-go/minimax-m2.7:high
# export SPINE_ENVOY_DEEPSEEK=openrouter/deepseek/deepseek-v3.2:high
# export SPINE_ENVOY_OPENCODE=opencode-go/minimax-m2.7:high  # generic best-of-breed fallback

# Per-tier overrides for OpenCode providers
# export SPINE_ENVOY_FRONTIER_GLM=opencode-go/glm-5:high
# export SPINE_ENVOY_STANDARD_GLM=opencode-go/glm-5:high
# export SPINE_ENVOY_FAST_GLM=openrouter/z-ai/glm-4.7-flash:minimal
# export SPINE_ENVOY_FRONTIER_MINIMAX=opencode-go/minimax-m2.7:high
# export SPINE_ENVOY_STANDARD_MINIMAX=opencode-go/minimax-m2.5:high
# export SPINE_ENVOY_FAST_MINIMAX=opencode/minimax-m2.5-free:minimal
# export SPINE_ENVOY_FRONTIER_DEEPSEEK=openrouter/deepseek/deepseek-v3.2:high  # speciale lacks tool-use on OpenRouter
# export SPINE_ENVOY_STANDARD_DEEPSEEK=openrouter/deepseek/deepseek-v3.2:high
# export SPINE_ENVOY_FAST_DEEPSEEK=openrouter/deepseek/deepseek-v3.2:minimal
# export SPINE_ENVOY_FRONTIER_OPENCODE=opencode-go/glm-5:high
# export SPINE_ENVOY_STANDARD_OPENCODE=opencode-go/minimax-m2.7:high
# export SPINE_ENVOY_FAST_OPENCODE=opencode/minimax-m2.5-free:minimal

# Cursor-agent fallback models (used when primary provider is unavailable)
# Composer-2 uses Auto+Composer pool. Override to API-pool model if pool exhausted.
# export SPINE_ENVOY_CLAUDE_CURSOR_FALLBACK=composer-2
# export SPINE_ENVOY_CODEX_CURSOR_FALLBACK=composer-2

# Copilot nesting sentinel: SPINE_ENVOY_COPILOT=1 (set by invoke-copilot.sh)
# COPILOT_MODEL stripped from copilot env to prevent model override conflicts

# Retry stack: provider cascade (run.sh) → multi-provider (@envoy)
