{
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/inject-agents-md.sh"
					}
				]
			},
			{
				"matcher": "compact",
				"hooks": [
					{
						"type": "command",
						"command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/inject-compact-essentials.sh"
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/guard-rm.sh"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write|MultiEdit",
				"hooks": [
					{
						"type": "command",
						"command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/check-on-edit.sh",
						"timeout": 30
					}
				]
			}
		],
		"PreCompact": [
			{
				"hooks": [
					{
						"type": "prompt",
						"prompt": "Context compaction is about to run. Before it does, capture current session state: run the do-handoff workflow to write a handoff artifact to .scratch/. Include all decisions made, rationale, rejected approaches, current state, and next steps. This is a safety net — write the artifact, then compaction will proceed."
					}
				]
			}
		]
	}
}
